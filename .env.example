# ─── Postgres (used by the db service in docker-compose) ───
POSTGRES_USER=studynotes
POSTGRES_PASSWORD=studynotes
POSTGRES_DB=studynotes

# ─── Backend ───
# Async SQLAlchemy URL (psycopg3 driver). When running the backend INSIDE docker
# the host is "db"; when running it natively on your machine use "localhost".
DATABASE_URL=postgresql+psycopg://studynotes:studynotes@db:5432/studynotes

# JWT signing key — CHANGE THIS to a long random string in production.
SECRET_KEY=dev-secret-change-me-please-0123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Create tables on startup without needing a migration (handy for first run).
AUTO_CREATE_TABLES=true

# Keep at most this many *automatic* versions per topic (named checkpoints are never pruned).
MAX_AUTO_VERSIONS=50

# Max upload size in megabytes.
MAX_UPLOAD_MB=10

# ─── Frontend ───
VITE_API_URL=http://localhost:8000/api
