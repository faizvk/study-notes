# Backend env for running NATIVELY (outside docker). Copy to backend/.env.
# Note host is localhost here (docker uses "db").
DATABASE_URL=postgresql+psycopg://studynotes:studynotes@localhost:5432/studynotes
SECRET_KEY=dev-secret-change-me-please-0123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTO_CREATE_TABLES=true
MAX_AUTO_VERSIONS=50
MAX_UPLOAD_MB=10
